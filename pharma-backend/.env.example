# ============================================================
#  TERANGA PHARMA BACKEND — .env
#  Variables d'environnement (NE PAS COMMITER sur GitHub)
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ── Base de données PostgreSQL ───────────────────────────────
# Option 1 : URL complète (Supabase, Railway, Render, Neon)
DATABASE_URL=postgresql://postgres:password@localhost:5432/teranga_pharma

# Option 2 : Paramètres séparés
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teranga_pharma
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET=teranga_pharma_secret_key_change_in_production_2025
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=teranga_pharma_refresh_secret_2025
JWT_REFRESH_EXPIRES_IN=30d

# ── Sécurité ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:5500,https://teranga-pharma.netlify.app

# ── SMS (Infobip) ─────────────────────────────────────────────
SMS_PROVIDER=infobip
SMS_API_KEY=your_infobip_api_key
SMS_SENDER=TERANGA
SMS_BASE_URL=https://api.infobip.com

# ── Email (optionnel) ─────────────────────────────────────────
EMAIL_FROM=noreply@teranga-pharma.sn
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Licences SaaS ─────────────────────────────────────────────
LICENCE_SECRET=teranga_licence_verify_2025
TRIAL_DAYS=30

# ── Cloud Storage (Supabase / Firebase) ──────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
