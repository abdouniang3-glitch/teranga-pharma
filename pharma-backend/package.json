    "express":           "^4.19.2",
    "express-rate-limit":"^7.3.1",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "morgan":            "^1.10.0",
    "pg":                "^8.12.0",
    "uuid":              "^10.0.0"
